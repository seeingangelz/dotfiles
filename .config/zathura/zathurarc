### Settings from original zathurarc ###
set statusbar-h-padding 0
set statusbar-v-padding 0
map r reload
map i color
map W toggle_page_mode

### zathura-pywal ###
# Allow recolor
set recolor 'true'

# Don't allow original hue when recoloring
set recolor-keephue 'false'

# Don't keep original image colors while recoloring
set recolor-reverse-video 'false'

# Command line completion entries
set completion-fg '#baabce'
set completion-bg '#050516'

# Command line completion group elements
set completion-group-fg '#1950AB'
set completion-group-bg '#050516'

# Current command line completion element
set completion-highlight-fg '#050516'
set completion-highlight-bg '#baabce'

# Default foreground/background color
set default-bg rgba(5,5,22,1)

# Input bar
set inputbar-fg '#baabce'
set inputbar-bg '#050516'

# Notification
set notification-fg '#baabce'
set notification-bg '#050516'

# Error notification
set notification-error-fg '#baabce'
set notification-error-bg '#413D8B'

# Warning notification
set notification-warning-fg '#baabce'
set notification-warning-bg '#413D8B'

# Tab - TODO
# set tabbar-fg
# set tabbar-bg

# Focused tab - TODO
# set tabbar-focus-fg
# set tabbar-focus-bg

# Status bar
set statusbar-fg '#baabce'
set statusbar-bg '#050516'

# Highlighting parts of the document (e.g. show search results)
set highlight-color '#1950AB'
set highlight-active-color '#1950AB'

# Represent light/dark colors in recoloring mode
set recolor-lightcolor rgba(0,0,0,0)
set recolor-darkcolor '#baabce'

# 'Loading...' text
set render-loading-fg '#baabce'
set render-loading-bg '#050516'

# Index mode
set index-fg '#baabce'
set index-bg '#050516'

# Selected element in index mode
set index-active-fg '#050516'
set index-active-bg '#baabce'