### Settings from original zathurarc ###
set statusbar-h-padding 0
set statusbar-v-padding 0
map r reload
map i color
map W toggle_page_mode

### zathura-pywal ###
# Allow recolor
set recolor 'true'

# Don't allow original hue when recoloring
set recolor-keephue 'false'

# Don't keep original image colors while recoloring
set recolor-reverse-video 'false'

# Command line completion entries
set completion-fg '#c1cbca'
set completion-bg '#0f0f10'

# Command line completion group elements
set completion-group-fg '#59666F'
set completion-group-bg '#0f0f10'

# Current command line completion element
set completion-highlight-fg '#0f0f10'
set completion-highlight-bg '#c1cbca'

# Default foreground/background color
set default-bg rgba(15,15,16,1)

# Input bar
set inputbar-fg '#c1cbca'
set inputbar-bg '#0f0f10'

# Notification
set notification-fg '#c1cbca'
set notification-bg '#0f0f10'

# Error notification
set notification-error-fg '#c1cbca'
set notification-error-bg '#4F5A64'

# Warning notification
set notification-warning-fg '#c1cbca'
set notification-warning-bg '#4F5A64'

# Tab - TODO
# set tabbar-fg
# set tabbar-bg

# Focused tab - TODO
# set tabbar-focus-fg
# set tabbar-focus-bg

# Status bar
set statusbar-fg '#c1cbca'
set statusbar-bg '#0f0f10'

# Highlighting parts of the document (e.g. show search results)
set highlight-color '#59666F'
set highlight-active-color '#59666F'

# Represent light/dark colors in recoloring mode
set recolor-lightcolor rgba(0,0,0,0)
set recolor-darkcolor '#c1cbca'

# 'Loading...' text
set render-loading-fg '#c1cbca'
set render-loading-bg '#0f0f10'

# Index mode
set index-fg '#c1cbca'
set index-bg '#0f0f10'

# Selected element in index mode
set index-active-fg '#0f0f10'
set index-active-bg '#c1cbca'