### Settings from original zathurarc ###
set statusbar-h-padding 0
set statusbar-v-padding 0
map r reload
map i color
map W toggle_page_mode

### zathura-pywal ###
# Allow recolor
set recolor 'true'

# Don't allow original hue when recoloring
set recolor-keephue 'false'

# Don't keep original image colors while recoloring
set recolor-reverse-video 'false'

# Command line completion entries
set completion-fg '#d3d3d3'
set completion-bg '#1b1b1b'

# Command line completion group elements
set completion-group-fg '#989898'
set completion-group-bg '#1b1b1b'

# Current command line completion element
set completion-highlight-fg '#1b1b1b'
set completion-highlight-bg '#d3d3d3'

# Default foreground/background color
set default-bg rgba(27,27,27,1)

# Input bar
set inputbar-fg '#d3d3d3'
set inputbar-bg '#1b1b1b'

# Notification
set notification-fg '#d3d3d3'
set notification-bg '#1b1b1b'

# Error notification
set notification-error-fg '#d3d3d3'
set notification-error-bg '#898989'

# Warning notification
set notification-warning-fg '#d3d3d3'
set notification-warning-bg '#898989'

# Tab - TODO
# set tabbar-fg
# set tabbar-bg

# Focused tab - TODO
# set tabbar-focus-fg
# set tabbar-focus-bg

# Status bar
set statusbar-fg '#d3d3d3'
set statusbar-bg '#1b1b1b'

# Highlighting parts of the document (e.g. show search results)
set highlight-color '#989898'
set highlight-active-color '#989898'

# Represent light/dark colors in recoloring mode
set recolor-lightcolor rgba(0,0,0,0)
set recolor-darkcolor '#d3d3d3'

# 'Loading...' text
set render-loading-fg '#d3d3d3'
set render-loading-bg '#1b1b1b'

# Index mode
set index-fg '#d3d3d3'
set index-bg '#1b1b1b'

# Selected element in index mode
set index-active-fg '#1b1b1b'
set index-active-bg '#d3d3d3'