### Settings from original zathurarc ###
set statusbar-h-padding 0
set statusbar-v-padding 0
map r reload
map i color
map W toggle_page_mode

### zathura-pywal ###
# Allow recolor
set recolor 'true'

# Don't allow original hue when recoloring
set recolor-keephue 'false'

# Don't keep original image colors while recoloring
set recolor-reverse-video 'false'

# Command line completion entries
set completion-fg '#e9e7e5'
set completion-bg '#0f0f12'

# Command line completion group elements
set completion-group-fg '#AA9EA2'
set completion-group-bg '#0f0f12'

# Current command line completion element
set completion-highlight-fg '#0f0f12'
set completion-highlight-bg '#e9e7e5'

# Default foreground/background color
set default-bg rgba(15,15,18,1)

# Input bar
set inputbar-fg '#e9e7e5'
set inputbar-bg '#0f0f12'

# Notification
set notification-fg '#e9e7e5'
set notification-bg '#0f0f12'

# Error notification
set notification-error-fg '#e9e7e5'
set notification-error-bg '#9E659B'

# Warning notification
set notification-warning-fg '#e9e7e5'
set notification-warning-bg '#9E659B'

# Tab - TODO
# set tabbar-fg
# set tabbar-bg

# Focused tab - TODO
# set tabbar-focus-fg
# set tabbar-focus-bg

# Status bar
set statusbar-fg '#e9e7e5'
set statusbar-bg '#0f0f12'

# Highlighting parts of the document (e.g. show search results)
set highlight-color '#AA9EA2'
set highlight-active-color '#AA9EA2'

# Represent light/dark colors in recoloring mode
set recolor-lightcolor rgba(0,0,0,0)
set recolor-darkcolor '#e9e7e5'

# 'Loading...' text
set render-loading-fg '#e9e7e5'
set render-loading-bg '#0f0f12'

# Index mode
set index-fg '#e9e7e5'
set index-bg '#0f0f12'

# Selected element in index mode
set index-active-fg '#0f0f12'
set index-active-bg '#e9e7e5'