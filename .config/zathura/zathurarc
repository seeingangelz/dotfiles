### Settings from original zathurarc ###
set statusbar-h-padding 0
set statusbar-v-padding 0
map r reload
map i color
map W toggle_page_mode

### zathura-pywal ###
# Allow recolor
set recolor 'true'

# Don't allow original hue when recoloring
set recolor-keephue 'false'

# Don't keep original image colors while recoloring
set recolor-reverse-video 'false'

# Command line completion entries
set completion-fg '#c7c1ab'
set completion-bg '#0c0c09'

# Command line completion group elements
set completion-group-fg '#535B45'
set completion-group-bg '#0c0c09'

# Current command line completion element
set completion-highlight-fg '#0c0c09'
set completion-highlight-bg '#c7c1ab'

# Default foreground/background color
set default-bg rgba(12,12,9,1)

# Input bar
set inputbar-fg '#c7c1ab'
set inputbar-bg '#0c0c09'

# Notification
set notification-fg '#c7c1ab'
set notification-bg '#0c0c09'

# Error notification
set notification-error-fg '#c7c1ab'
set notification-error-bg '#685839'

# Warning notification
set notification-warning-fg '#c7c1ab'
set notification-warning-bg '#685839'

# Tab - TODO
# set tabbar-fg
# set tabbar-bg

# Focused tab - TODO
# set tabbar-focus-fg
# set tabbar-focus-bg

# Status bar
set statusbar-fg '#c7c1ab'
set statusbar-bg '#0c0c09'

# Highlighting parts of the document (e.g. show search results)
set highlight-color '#535B45'
set highlight-active-color '#535B45'

# Represent light/dark colors in recoloring mode
set recolor-lightcolor rgba(0,0,0,0)
set recolor-darkcolor '#c7c1ab'

# 'Loading...' text
set render-loading-fg '#c7c1ab'
set render-loading-bg '#0c0c09'

# Index mode
set index-fg '#c7c1ab'
set index-bg '#0c0c09'

# Selected element in index mode
set index-active-fg '#0c0c09'
set index-active-bg '#c7c1ab'