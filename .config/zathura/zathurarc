### Settings from original zathurarc ###
set statusbar-h-padding 0
set statusbar-v-padding 0
map r reload
map i color
map W toggle_page_mode

### zathura-pywal ###
# Allow recolor
set recolor 'true'

# Don't allow original hue when recoloring
set recolor-keephue 'false'

# Don't keep original image colors while recoloring
set recolor-reverse-video 'false'

# Command line completion entries
set completion-fg '#acacac'
set completion-bg '#020202'

# Command line completion group elements
set completion-group-fg '#434343'
set completion-group-bg '#020202'

# Current command line completion element
set completion-highlight-fg '#020202'
set completion-highlight-bg '#acacac'

# Default foreground/background color
set default-bg rgba(2,2,2,1)

# Input bar
set inputbar-fg '#acacac'
set inputbar-bg '#020202'

# Notification
set notification-fg '#acacac'
set notification-bg '#020202'

# Error notification
set notification-error-fg '#acacac'
set notification-error-bg '#3B3B3B'

# Warning notification
set notification-warning-fg '#acacac'
set notification-warning-bg '#3B3B3B'

# Tab - TODO
# set tabbar-fg
# set tabbar-bg

# Focused tab - TODO
# set tabbar-focus-fg
# set tabbar-focus-bg

# Status bar
set statusbar-fg '#acacac'
set statusbar-bg '#020202'

# Highlighting parts of the document (e.g. show search results)
set highlight-color '#434343'
set highlight-active-color '#434343'

# Represent light/dark colors in recoloring mode
set recolor-lightcolor rgba(0,0,0,0)
set recolor-darkcolor '#acacac'

# 'Loading...' text
set render-loading-fg '#acacac'
set render-loading-bg '#020202'

# Index mode
set index-fg '#acacac'
set index-bg '#020202'

# Selected element in index mode
set index-active-fg '#020202'
set index-active-bg '#acacac'