### Settings from original zathurarc ###
set statusbar-h-padding 0
set statusbar-v-padding 0
map r reload
map i color
map W toggle_page_mode

### zathura-pywal ###
# Allow recolor
set recolor 'true'

# Don't allow original hue when recoloring
set recolor-keephue 'false'

# Don't keep original image colors while recoloring
set recolor-reverse-video 'false'

# Command line completion entries
set completion-fg '#a9b6bc'
set completion-bg '#0c0c0d'

# Command line completion group elements
set completion-group-fg '#676454'
set completion-group-bg '#0c0c0d'

# Current command line completion element
set completion-highlight-fg '#0c0c0d'
set completion-highlight-bg '#a9b6bc'

# Default foreground/background color
set default-bg rgba(12,12,13,1)

# Input bar
set inputbar-fg '#a9b6bc'
set inputbar-bg '#0c0c0d'

# Notification
set notification-fg '#a9b6bc'
set notification-bg '#0c0c0d'

# Error notification
set notification-error-fg '#a9b6bc'
set notification-error-bg '#314049'

# Warning notification
set notification-warning-fg '#a9b6bc'
set notification-warning-bg '#314049'

# Tab - TODO
# set tabbar-fg
# set tabbar-bg

# Focused tab - TODO
# set tabbar-focus-fg
# set tabbar-focus-bg

# Status bar
set statusbar-fg '#a9b6bc'
set statusbar-bg '#0c0c0d'

# Highlighting parts of the document (e.g. show search results)
set highlight-color '#676454'
set highlight-active-color '#676454'

# Represent light/dark colors in recoloring mode
set recolor-lightcolor rgba(0,0,0,0)
set recolor-darkcolor '#a9b6bc'

# 'Loading...' text
set render-loading-fg '#a9b6bc'
set render-loading-bg '#0c0c0d'

# Index mode
set index-fg '#a9b6bc'
set index-bg '#0c0c0d'

# Selected element in index mode
set index-active-fg '#0c0c0d'
set index-active-bg '#a9b6bc'