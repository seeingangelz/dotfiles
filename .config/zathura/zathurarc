### Settings from original zathurarc ###
set statusbar-h-padding 0
set statusbar-v-padding 0
map r reload
map i color
map W toggle_page_mode

### zathura-pywal ###
# Allow recolor
set recolor 'true'

# Don't allow original hue when recoloring
set recolor-keephue 'false'

# Don't keep original image colors while recoloring
set recolor-reverse-video 'false'

# Command line completion entries
set completion-fg '#beaf96'
set completion-bg '#0F1215'

# Command line completion group elements
set completion-group-fg '#364854'
set completion-group-bg '#0F1215'

# Current command line completion element
set completion-highlight-fg '#0F1215'
set completion-highlight-bg '#beaf96'

# Default foreground/background color
set default-bg rgba(15,18,21,1)

# Input bar
set inputbar-fg '#beaf96'
set inputbar-bg '#0F1215'

# Notification
set notification-fg '#beaf96'
set notification-bg '#0F1215'

# Error notification
set notification-error-fg '#beaf96'
set notification-error-bg '#2A3B45'

# Warning notification
set notification-warning-fg '#beaf96'
set notification-warning-bg '#2A3B45'

# Tab - TODO
# set tabbar-fg
# set tabbar-bg

# Focused tab - TODO
# set tabbar-focus-fg
# set tabbar-focus-bg

# Status bar
set statusbar-fg '#beaf96'
set statusbar-bg '#0F1215'

# Highlighting parts of the document (e.g. show search results)
set highlight-color '#364854'
set highlight-active-color '#364854'

# Represent light/dark colors in recoloring mode
set recolor-lightcolor rgba(0,0,0,0)
set recolor-darkcolor '#beaf96'

# 'Loading...' text
set render-loading-fg '#beaf96'
set render-loading-bg '#0F1215'

# Index mode
set index-fg '#beaf96'
set index-bg '#0F1215'

# Selected element in index mode
set index-active-fg '#0F1215'
set index-active-bg '#beaf96'