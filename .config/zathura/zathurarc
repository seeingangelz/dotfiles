### Settings from original zathurarc ###
set statusbar-h-padding 0
set statusbar-v-padding 0
map r reload
map i color
map W toggle_page_mode

### zathura-pywal ###
# Allow recolor
set recolor 'true'

# Don't allow original hue when recoloring
set recolor-keephue 'false'

# Don't keep original image colors while recoloring
set recolor-reverse-video 'false'

# Command line completion entries
set completion-fg '#addaf5'
set completion-bg '#181219'

# Command line completion group elements
set completion-group-fg '#645B77'
set completion-group-bg '#181219'

# Current command line completion element
set completion-highlight-fg '#181219'
set completion-highlight-bg '#addaf5'

# Default foreground/background color
set default-bg rgba(24,18,25,1)

# Input bar
set inputbar-fg '#addaf5'
set inputbar-bg '#181219'

# Notification
set notification-fg '#addaf5'
set notification-bg '#181219'

# Error notification
set notification-error-fg '#addaf5'
set notification-error-bg '#504E6E'

# Warning notification
set notification-warning-fg '#addaf5'
set notification-warning-bg '#504E6E'

# Tab - TODO
# set tabbar-fg
# set tabbar-bg

# Focused tab - TODO
# set tabbar-focus-fg
# set tabbar-focus-bg

# Status bar
set statusbar-fg '#addaf5'
set statusbar-bg '#181219'

# Highlighting parts of the document (e.g. show search results)
set highlight-color '#645B77'
set highlight-active-color '#645B77'

# Represent light/dark colors in recoloring mode
set recolor-lightcolor rgba(0,0,0,0)
set recolor-darkcolor '#addaf5'

# 'Loading...' text
set render-loading-fg '#addaf5'
set render-loading-bg '#181219'

# Index mode
set index-fg '#addaf5'
set index-bg '#181219'

# Selected element in index mode
set index-active-fg '#181219'
set index-active-bg '#addaf5'