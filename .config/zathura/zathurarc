### Settings from original zathurarc ###
set statusbar-h-padding 0
set statusbar-v-padding 0
map r reload
map i color
map W toggle_page_mode

### zathura-pywal ###
# Allow recolor
set recolor 'true'

# Don't allow original hue when recoloring
set recolor-keephue 'false'

# Don't keep original image colors while recoloring
set recolor-reverse-video 'false'

# Command line completion entries
set completion-fg '#c5c4bd'
set completion-bg '#121319'

# Command line completion group elements
set completion-group-fg '#7E8078'
set completion-group-bg '#121319'

# Current command line completion element
set completion-highlight-fg '#121319'
set completion-highlight-bg '#c5c4bd'

# Default foreground/background color
set default-bg rgba(18,19,25,1)

# Input bar
set inputbar-fg '#c5c4bd'
set inputbar-bg '#121319'

# Notification
set notification-fg '#c5c4bd'
set notification-bg '#121319'

# Error notification
set notification-error-fg '#c5c4bd'
set notification-error-bg '#60696D'

# Warning notification
set notification-warning-fg '#c5c4bd'
set notification-warning-bg '#60696D'

# Tab - TODO
# set tabbar-fg
# set tabbar-bg

# Focused tab - TODO
# set tabbar-focus-fg
# set tabbar-focus-bg

# Status bar
set statusbar-fg '#c5c4bd'
set statusbar-bg '#121319'

# Highlighting parts of the document (e.g. show search results)
set highlight-color '#7E8078'
set highlight-active-color '#7E8078'

# Represent light/dark colors in recoloring mode
set recolor-lightcolor rgba(0,0,0,0)
set recolor-darkcolor '#c5c4bd'

# 'Loading...' text
set render-loading-fg '#c5c4bd'
set render-loading-bg '#121319'

# Index mode
set index-fg '#c5c4bd'
set index-bg '#121319'

# Selected element in index mode
set index-active-fg '#121319'
set index-active-bg '#c5c4bd'