### Settings from original zathurarc ###
set statusbar-h-padding 0
set statusbar-v-padding 0
map r reload
map i color
map W toggle_page_mode

### zathura-pywal ###
# Allow recolor
set recolor 'true'

# Don't allow original hue when recoloring
set recolor-keephue 'false'

# Don't keep original image colors while recoloring
set recolor-reverse-video 'false'

# Command line completion entries
set completion-fg '#a5dff2'
set completion-bg '#200d2a'

# Command line completion group elements
set completion-group-fg '#421EC0'
set completion-group-bg '#200d2a'

# Current command line completion element
set completion-highlight-fg '#200d2a'
set completion-highlight-bg '#a5dff2'

# Default foreground/background color
set default-bg rgba(32,13,42,1)

# Input bar
set inputbar-fg '#a5dff2'
set inputbar-bg '#200d2a'

# Notification
set notification-fg '#a5dff2'
set notification-bg '#200d2a'

# Error notification
set notification-error-fg '#a5dff2'
set notification-error-bg '#3930C9'

# Warning notification
set notification-warning-fg '#a5dff2'
set notification-warning-bg '#3930C9'

# Tab - TODO
# set tabbar-fg
# set tabbar-bg

# Focused tab - TODO
# set tabbar-focus-fg
# set tabbar-focus-bg

# Status bar
set statusbar-fg '#a5dff2'
set statusbar-bg '#200d2a'

# Highlighting parts of the document (e.g. show search results)
set highlight-color '#421EC0'
set highlight-active-color '#421EC0'

# Represent light/dark colors in recoloring mode
set recolor-lightcolor rgba(0,0,0,0)
set recolor-darkcolor '#a5dff2'

# 'Loading...' text
set render-loading-fg '#a5dff2'
set render-loading-bg '#200d2a'

# Index mode
set index-fg '#a5dff2'
set index-bg '#200d2a'

# Selected element in index mode
set index-active-fg '#200d2a'
set index-active-bg '#a5dff2'