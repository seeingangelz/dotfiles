### Settings from original zathurarc ###
set statusbar-h-padding 0
set statusbar-v-padding 0
map r reload
map i color
map W toggle_page_mode

### zathura-pywal ###
# Allow recolor
set recolor 'true'

# Don't allow original hue when recoloring
set recolor-keephue 'false'

# Don't keep original image colors while recoloring
set recolor-reverse-video 'false'

# Command line completion entries
set completion-fg '#c5c7c8'
set completion-bg '#131215'

# Command line completion group elements
set completion-group-fg '#737D82'
set completion-group-bg '#131215'

# Current command line completion element
set completion-highlight-fg '#131215'
set completion-highlight-bg '#c5c7c8'

# Default foreground/background color
set default-bg rgba(19,18,21,1)

# Input bar
set inputbar-fg '#c5c7c8'
set inputbar-bg '#131215'

# Notification
set notification-fg '#c5c7c8'
set notification-bg '#131215'

# Error notification
set notification-error-fg '#c5c7c8'
set notification-error-bg '#687175'

# Warning notification
set notification-warning-fg '#c5c7c8'
set notification-warning-bg '#687175'

# Tab - TODO
# set tabbar-fg
# set tabbar-bg

# Focused tab - TODO
# set tabbar-focus-fg
# set tabbar-focus-bg

# Status bar
set statusbar-fg '#c5c7c8'
set statusbar-bg '#131215'

# Highlighting parts of the document (e.g. show search results)
set highlight-color '#737D82'
set highlight-active-color '#737D82'

# Represent light/dark colors in recoloring mode
set recolor-lightcolor rgba(0,0,0,0)
set recolor-darkcolor '#c5c7c8'

# 'Loading...' text
set render-loading-fg '#c5c7c8'
set render-loading-bg '#131215'

# Index mode
set index-fg '#c5c7c8'
set index-bg '#131215'

# Selected element in index mode
set index-active-fg '#131215'
set index-active-bg '#c5c7c8'